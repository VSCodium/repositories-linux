root = true

[*]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[{*.yml,*.yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 4

[*.patch]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = false

[*.sh]
indent_style = space
indent_size = 2

[*.svg]
insert_final_newline = false

[*.{html,html.liquid,json}]
indent_style = tab
indent_size = 4
tab_width = 4
